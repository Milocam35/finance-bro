{
  "permissions": {
    "allow": [
      "Bash(if exist .git rmdir /s /q .git)",
      "Bash(git init:*)",
      "Bash(if [ -d \"finance-hub-main/.git\" ])",
      "Bash(then rm -rf \"finance-hub-main/.git\")",
      "Bash(else echo \"No existe repositorio en finance-hub-main\")",
      "Bash(fi)",
      "Bash(npm install:*)",
      "Bash(del *.webp)",
      "mcp__n8n-mcp__*",
      "Bash(docker exec:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "n8n-mcp-skills@n8n-skills": true
  },
  "extraKnownMarketplaces": {
    "n8n-skills": {
      "source": {
        "source": "github",
        "repo": "czlonkowski/n8n-skills"
      }
    }
  }
}
