# ============================================
# FinanceBro API - Environment Variables
# ============================================

# ============================================
# Database Configuration
# ============================================
# OPCIÓN A — Postgres local (Docker). Se usa si DATABASE_URL está vacía:
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=financebro
DATABASE_PASSWORD=password123
DATABASE_NAME=financebro_db

# OPCIÓN B — Postgres gestionado (Supabase). Si defines DATABASE_URL, tiene
# prioridad sobre las variables de arriba y activa SSL automáticamente.
#   - Runtime (DATABASE_URL): pooler de TRANSACCIÓN, puerto 6543
#   - Migraciones (DATABASE_MIGRATION_URL): pooler de SESIÓN, puerto 5432
# DATABASE_URL=postgresql://postgres.<REF>:<PASSWORD>@aws-1-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require
# DATABASE_MIGRATION_URL=postgresql://postgres.<REF>:<PASSWORD>@aws-1-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require
# DATABASE_SSL=true   # auto-activado con DATABASE_URL; usar solo para forzar/desactivar

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# API Configuration
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# Security
# ============================================
# Cambia estos valores en producción
N8N_API_KEY=tu_clave_secreta_para_n8n
JWT_SECRET=secret_jwt_key_change_in_production
JWT_EXPIRATION=7d

# ============================================
# TypeORM Configuration
# ============================================
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=false
