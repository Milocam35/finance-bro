# ============================================
# FinanceBro - Docker Environment Variables
# ============================================
# Copia este archivo a .env y actualiza los valores

# ============================================
# PostgreSQL
# ============================================
POSTGRES_USER=financebro
POSTGRES_PASSWORD=password123_change_in_production
POSTGRES_DB=financebro_db
POSTGRES_PORT=5432

# ============================================
# Redis
# ============================================
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_in_production

# ============================================
# Backend API
# ============================================
BACKEND_PORT=3000
N8N_API_KEY=tu_clave_secreta_para_n8n_change_this
JWT_SECRET=secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRATION=7d
TYPEORM_LOGGING=false

# ============================================
# Frontend
# ============================================
FRONTEND_PORT=5173
# Para desarrollo usa: http://localhost:3000
# Para producción usa: /api (proxy de Nginx)
VITE_API_URL=http://localhost:3000

# ============================================
# PgAdmin (opcional)
# ============================================
PGADMIN_EMAIL=admin@financebro.com
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050

# ============================================
# Notas:
# ============================================
# - En DESARROLLO: docker compose up
# - En PRODUCCIÓN: docker compose -f docker-compose.prod.yml up -d
# - PgAdmin solo en desarrollo: docker compose --profile tools up
