# ============================================
# FinanceBro - Docker Environment Variables
# ============================================
# Copia este archivo a .env y actualiza los valores.
# DESARROLLO usa docker-compose.yml (postgres/redis locales).
# PRODUCCIÓN usa docker-compose.prod.yml (DB en Supabase, n8n + Caddy).

# ============================================
# DESARROLLO (docker-compose.yml) — postgres/redis locales
# ============================================
POSTGRES_USER=financebro
POSTGRES_PASSWORD=password123_change_in_production
POSTGRES_DB=financebro_db
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=3000
FRONTEND_PORT=5173
PGADMIN_EMAIL=admin@financebro.com
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050

# ============================================
# PRODUCCIÓN (docker-compose.prod.yml)
# ============================================

# --- Dominio / TLS (Caddy) ---
DOMAIN=tudominio.co
ACME_EMAIL=tu-correo@ejemplo.com

# --- TESTING por IP (sin dominio) — solo para docker-compose.testing.yml ---
# IP pública del VPS. n8n y CORS la usan en modo HTTP.
VPS_IP=123.45.67.89
# URL del quick tunnel de Playwright (cloudflared tunnel --url http://localhost:3001).
# Cambia en cada reinicio; pégala aquí para que n8n alcance tu Playwright local.
PDF_SERVICE_URL=

# --- Base de datos: Supabase (la app NO usa postgres local en prod) ---
# Proyecto PRODUCTOS (runtime pooler 6543 / migraciones pooler 5432)
BACKEND_DATABASE_URL=postgresql://postgres.<REF_PRODUCTOS>:<PASSWORD>@aws-1-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require
BACKEND_MIGRATION_URL=postgresql://postgres.<REF_PRODUCTOS>:<PASSWORD>@aws-1-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require
# Proyecto USUARIOS (auth)
USERS_DATABASE_URL=postgresql://postgres.<REF_USUARIOS>:<PASSWORD>@aws-1-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require
USERS_MIGRATION_URL=postgresql://postgres.<REF_USUARIOS>:<PASSWORD>@aws-1-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require

# --- Redis (caché de la app) ---
REDIS_PASSWORD=redis_password_change_in_production

# --- Seguridad de la app ---
N8N_API_KEY=clave_compartida_api_ingesta_change_this
JWT_SECRET=secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRATION=7d
TYPEORM_LOGGING=false

# Frontend: en prod usa /api (proxy mismo origen vía nginx). En dev: http://localhost:3000
VITE_API_URL=/api

# --- n8n autohospedado ---
# Genera con: openssl rand -hex 32
N8N_ENCRYPTION_KEY=cambia_esto_por_32_bytes_hex
N8N_DB_PASSWORD=password_de_la_db_de_n8n_change_this

# --- Playwright local (Cloudflare Named Tunnel) ---
# Misma clave que configures en playwright-pdf-service (API_KEY) en tu máquina local
PLAYWRIGHT_API_KEY=clave_fuerte_para_playwright_change_this

# --- ScraperAPI (anti-bot usado por ScrapingEngine) ---
# Estaba hardcodeada en el workflow (filtrada en git) → ROTAR en scraperapi.com
SCRAPERAPI_KEY=tu_api_key_de_scraperapi_change_this

# ============================================
# Notas:
# ============================================
# - DESARROLLO:  docker compose up
# - PRODUCCIÓN:  docker compose -f docker-compose.prod.yml up -d
# - Nunca commitear el .env con valores reales (cubierto por .gitignore).
