# Servidor
PORT=3001
NODE_ENV=development

# Base de datos — usa DB aislada financebro_users_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=financebro
DATABASE_PASSWORD=password123
DATABASE_NAME=financebro_users_db

# JWT
JWT_SECRET=change_this_to_a_strong_random_secret_in_production
JWT_EXPIRATION=7d

# TypeORM
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=false

# CORS (separados por coma para producción)
# CORS_ORIGIN=https://financebro.co,https://www.financebro.co
