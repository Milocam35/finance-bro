# ============================================
# FinanceBro Frontend - Environment Variables
# ============================================

# ============================================
# API Configuration
# ============================================
# URL del backend API
# Desarrollo local: http://localhost:3000
# Desarrollo con Docker: http://localhost:3000
# Producción: /api (proxy de Nginx)
VITE_API_URL=http://localhost:3000

# ============================================
# Environment
# ============================================
NODE_ENV=development

# ============================================
# Notas:
# ============================================
# - Las variables VITE_* son expuestas al navegador
# - Nunca pongas secrets en variables VITE_*
# - El build de producción usa VITE_API_URL=/api por defecto
